# Cloudflare CDN / Images (optional)
# Without these, the prototype uses picsum.photos fallbacks.

# Mode: off | cdn | images
# Use `cdn` with local files in public/assets/ (see media-catalog.ts)
NEXT_PUBLIC_CF_MEDIA_MODE=cdn

# Local dev: files in public/assets/ are served at /assets/...
NEXT_PUBLIC_CF_CDN_BASE_URL=http://localhost:3000

# Disable on localhost — /cdn-cgi/image only works on a Cloudflare zone
NEXT_PUBLIC_CF_IMAGE_RESIZING=false

# Production: custom domain on Cloudflare (R2, Workers, or zone static assets)
# NEXT_PUBLIC_CF_CDN_BASE_URL=https://assets.your-charity-hub-domain.com
# NEXT_PUBLIC_CF_IMAGE_RESIZING=true

# --- OR use Cloudflare Images instead of R2 / local assets ---
# NEXT_PUBLIC_CF_MEDIA_MODE=images
# NEXT_PUBLIC_CF_IMAGES_ACCOUNT_HASH=your_account_hash_from_dashboard
# NEXT_PUBLIC_CF_IMAGES_DEFAULT_VARIANT=public
# NEXT_PUBLIC_CF_IMAGES_WIDTH_VARIANT_PREFIX=w

# --- Optional: Cloudflare Stream for feed videos ---
# NEXT_PUBLIC_CF_STREAM_BASE_URL=https://customer-xxxxx.cloudflarestream.com
